VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Signaling/SFU server URL — defaults to http://localhost:3000 if unset
VITE_SERVER_URL=

# TURN relay for clients on hostile networks (optional; STUN-only without it).
# Comma-separate multiple transports; turns:...:443 is the one that gets through
# the strictest firewalls. Prefer short-lived (HMAC) credentials in production.
# VITE_TURN_URL=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:443?transport=tcp
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
