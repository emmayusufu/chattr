PORT=3000

# Public-routable IP that mediasoup announces in ICE candidates.
# Auto-detected from the first non-loopback interface if unset.
MEDIASOUP_ANNOUNCED_IP=

# Origin allowed to connect via Socket.IO. Use the actual deployed
# client origin in production (e.g. https://chattr.jengahq.com).
# Defaults to "*" for local development.
CLIENT_ORIGIN=

# mediasoup UDP port range for media transports. Whatever range you set
# here, open the same range in your cloud firewall. Defaults to 10000-10100
# (≈50 simultaneous calls of room capacity, plenty for tutoring).
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100

# Capacity caps.
MAX_USERS_PER_ROOM=16
MAX_ROOMS=100

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=
